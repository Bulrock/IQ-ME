#!/usr/bin/env node
// Thin shim: locate the TDS-runtime bundle relative to this script and
// delegate. Two layouts are supported:
//   - Source tree:  <repo>/payload/bin/tds → <repo>/payload/shared/tds-runtime.bundle.js
//   - Installed:    _bmad/tds/bin/tds       → _bmad/tds/shared/tds-runtime.bundle.js
// Both reduce to `../shared/tds-runtime.bundle.js`.
//
// Tags TDS_INVOCATION_FORM=project-shim (only when not already set, so
// upstream global-shim's value survives). Bundle reads the var in the
// dispatcher and emits it on every cli-events row for adoption metrics.
import { spawnSync } from "node:child_process";
import { dirname, resolve } from "node:path";
import { fileURLToPath } from "node:url";

const here = dirname(fileURLToPath(import.meta.url));
const bundle = resolve(here, "..", "shared", "tds-runtime.bundle.js");
if (!process.env.TDS_INVOCATION_FORM) {
  process.env.TDS_INVOCATION_FORM = "project-shim";
}
const r = spawnSync(process.execPath, [bundle, ...process.argv.slice(2)], {
  stdio: "inherit",
});
process.exit(r.status ?? 1);
